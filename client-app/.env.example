# CLIENT TUI environment
# Default LXC API endpoint if no per-stack override is present.
LXC_API_IP=127.0.0.1

# Optional bearer token for LXC /api/sync calls.
LXC_API_TOKEN=

# Optional OPNsense API settings for DHCP reservation automation.
OPNSENSE_BASE_URL=https://10.10.5.1
OPNSENSE_API_KEY=
OPNSENSE_API_SECRET=
OPNSENSE_TLS_INSECURE=false

# Optional per-stack endpoint overrides used when CLIENT dispatches sync requests.
LXC_CLOUDFLARED_IP=10.0.1.101
LXC_DOWNLOADER_IP=10.0.1.102
LXC_GATEWAY_IP=10.0.1.103
LXC_MEDIA_IP=10.0.1.104
LXC_MONITORING_IP=10.0.1.105
LXC_PAPERLESS_IP=10.0.1.106
LXC_VIKUNJA_IP=10.0.1.107
