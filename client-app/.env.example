# CLIENT TUI environment
# Default LXC API endpoint if no per-stack override is present.
LXC_API_IP=

# Optional bearer token for LXC /api/sync calls.
LXC_API_TOKEN=

# HOST connectivity target (used for inverse failsafe suppression and host probes).
# CLIENT executes SSH directly against HOST_SSH_TARGET, or HOST_SSH_USER@HOST_IP if target is empty.
HOST_IP=
HOST_SSH_USER=
HOST_SSH_TARGET=
HOST_HEARTBEAT_FILE=

# Optional OPNsense API settings for DHCP reservation automation.
OPNSENSE_BASE_URL=
OPNSENSE_API_KEY=
OPNSENSE_API_SECRET=
OPNSENSE_TLS_INSECURE=

# Latch credentials used by CLIENT for secrets sync and machine clone.

# Optional per-stack endpoint overrides used when CLIENT dispatches sync requests.
DOMAIN=
STACK_IP_PREFIX=