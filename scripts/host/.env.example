# Environment variables for Proxmox host scripts (e.g., bootstrap-lxc.sh)
# Copy this file to .env and fill in your details to automate the bootstrap wizard.

# Your GitHub Username (used to fetch public SSH keys: https://github.com/<username>.keys)
GITHUB_USERNAME=your_github_username_here

# Your GitHub Personal Access Token (PAT) for cloning the private repository
GITHUB_PAT=your_github_pat_here

# The passphrase for your Age private key (used by SOPS to decrypt secrets)
AGE_PASSPHRASE=your_age_passphrase_here
