# Environment variables for Proxmox host scripts (e.g., bootstrap-lxc.sh, backup-stacks.sh)
# Copy this file to .env and fill in your details.
# Permissions MUST be: chmod 600 .env  (never commit this file to Git)

# Your GitHub Username (used to fetch public SSH keys: https://github.com/<username>.keys)
GITHUB_USERNAME=your_github_username_here

# Your GitHub Personal Access Token (PAT) for cloning the private repository
GITHUB_PAT=your_github_pat_here

# The passphrase for your Age private key (used by SOPS to decrypt secrets)
AGE_PASSPHRASE=your_age_passphrase_here

# Restic backup credentials
# RESTIC_REPOSITORY: path or URL to the backup target (e.g. /HDD2TB/backups/restic or s3:// ...)
RESTIC_REPOSITORY=/HDD2TB/backups/restic
RESTIC_PASSWORD=your_restic_repository_password_here
