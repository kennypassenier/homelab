# The public URL where Vikunja is reachable (used in notification links, OAuth redirects, etc.)
# Must match the URL configured in Nginx Proxy Manager.
VIKUNJA_SERVICE_PUBLICURL=
# A random, stable secret used to sign session tokens.
# Generate with: openssl rand -hex 32
# Without this, every container restart invalidates all active sessions.
VIKUNJA_SERVICE_SECRET=