# Homelab Central Configuration (Active)
#
# This is the SINGLE SOURCE OF TRUTH for all runtime environment variables across CLIENT, HOST, and LXC daemons.
# Each variable is documented with: purpose, default, and instructions on obtaining the correct value.
#
# Environment precedence for each daemon:
# - CLIENT: CLIENT_ENV_FILE → config/.env → no env
# - HOST: HOST_ENV_FILE → config/.env → no env
# - LXC: LXC_ENV_FILE → config/.env → no env

# =============================================================================
# CORE NETWORKING & API
# =============================================================================

# LXC_API_IP - Default HTTP endpoint for LXC daemon API (fallback when no reserved IPv4)
# - Used when a stack has no reserved_ipv4 in stacks/<name>/lxc-compose.yml
# - Typical: 127.0.0.1 (localhost) for single-LXC or dev; otherwise use container IP
LXC_API_IP=

# LXC_API_TOKEN - Bearer token for LXC daemon /api/* endpoints and WebSocket authentication
# - Also used by HOST /api/metrics bearer auth when configured
# - Shared across all LXC instances and CLIENT
# - Generate: openssl rand -hex 32
# - SENSITIVE: treat as password
LXC_API_TOKEN=

# HOST_IP - IP address of the Proxmox host for CLIENT Host Management metrics retrieval
# - HOST daemon listens on HTTP :8080 for /api/metrics endpoint
# - CLIENT uses this to fetch runtime data (hostname, uptime, LXC list) instead of SSH
HOST_IP=

# =============================================================================
# CLIENT BEHAVIOR & ORCHESTRATION
# =============================================================================

# BACKUP_ID_DEFAULT - Default backup snapshot ID shown in CLIENT restore workflow
# - Typical value: "latest" for most users
# - Alternative: specific backup ID from restic repo (e.g., "2024-01-15T12:00:00Z")
BACKUP_ID_DEFAULT=

# HOST_UPDATE_REPO - GitHub repository for HOST daemon release-based updates
# - Format: owner/repo (no .git suffix)
# - CLIENT queries owner/repo/releases to find host-daemon-v* tags and download HOST asset
HOST_UPDATE_REPO=

# LXC_DAEMON_IMAGE - Docker/OCI image source for LXC daemon self-updates
# - Format: ghcr.io/owner/repo-lxc-daemon:tag
# - LXC daemon checks for image updates during sync cycles
LXC_DAEMON_IMAGE=

# DOMAIN - Base domain suffix for Traefik app wizard subdomain configuration
# - Used when creating Traefik-enabled apps
# - Wizard prompt: "subdomain?" → user enters "example" → full DNS name: example.{DOMAIN}
DOMAIN=

# STACK_IP_PREFIX - Network prefix for deriving stack reserved IPv4 addresses
# - Formula: reserved_ipv4 = {STACK_IP_PREFIX} + (vmid - 100)
# - Example: prefix=10.10.10., vmid=105 → reserved_ipv4=10.10.10.5
# - Choose prefix that doesn't conflict with your network (typically a /24 subnet)
STACK_IP_PREFIX=

# =============================================================================
# OPNSENSE INTEGRATION (Optional - for DHCP reservation sync)
# =============================================================================
# Enable CLIENT to automatically sync stack DHCP reservations to your OPNsense firewall.
# Leave these empty to disable DHCP automation.

# OPNSENSE_BASE_URL - Base URL of OPNsense API endpoint
# - Example: https://10.10.5.1
# - Verify by accessing OPNsense web UI in your browser
OPNSENSE_BASE_URL=

# OPNSENSE_API_KEY - API key for OPNsense authentication
# - Obtain from: OPNsense WebUI → System → Access → Users → Select your user
#   → API Keys section → Generate new key
OPNSENSE_API_KEY=

# OPNSENSE_API_SECRET - API secret paired with OPNSENSE_API_KEY
# - Generated together with API_KEY in OPNsense (shown once—save immediately)
# - SENSITIVE: treat as password
OPNSENSE_API_SECRET=

# OPNSENSE_TLS_INSECURE - Skip TLS certificate verification for OPNsense API
# - Set to true ONLY for lab/self-signed TLS setups
# - NEVER use in production
OPNSENSE_TLS_INSECURE=

# =============================================================================
# GIT & REPOSITORY CONFIGURATION
# =============================================================================

# GITOPS_REPO - Absolute filesystem path to the GitOps repository on the Proxmox host
# - Typical: /root/homelab (result of cloning the repo on the HOST machine)
# - HOST daemon uses this path to find stacks/ and scripts/ directories
GITOPS_REPO=

# GITOPS_REPO_URL - Git remote URL for cloning/pulling the GitOps repository
# - Format: https://github.com/owner/repo.git or git@github.com:owner/repo.git
# - Used by HOST for git pull operations and by LXC for sparse-checkout cloning
GITOPS_REPO_URL=

# GITHUB_USERNAME - GitHub username for fetching public SSH keys during LXC bootstrap
# - Used to fetch keys from: https://github.com/{username}.keys
# - Public data (safe to commit to Git)
GITHUB_USERNAME=

# GITHUB_PAT - GitHub Personal Access Token for private repository access
# - Generate from: GitHub → Settings → Developer settings → Personal access tokens
# - Requires: 'repo' scope (full control of private repositories)
# - SENSITIVE: Never commit this value
GITHUB_PAT=

# =============================================================================
# SECRET MANAGEMENT (Latch)
# =============================================================================

# LATCH_PAT - Latch Personal Access Token for secret synchronization
# - Used by HOST and LXC for non-interactive secret cloning/sync flows
# - Obtain from your Latch infrastructure administrator
# - SENSITIVE: Never commit this value
LATCH_PAT=

# LATCH_KEY - Latch encryption key paired with LATCH_PAT
# - Generated and distributed by Latch administrator together with LATCH_PAT
# - SENSITIVE: Never commit this value
LATCH_KEY=

# LATCH_SECRETS_REPO - GitHub repository where latch-managed secrets are stored
# - Used by `latch login` on HOST and LXC to configure the secrets remote
# - Format: owner/repo (no .git suffix)
# - Passed as: latch login --PAT <LATCH_PAT> --KEY <LATCH_KEY> --REPO <LATCH_SECRETS_REPO>
LATCH_SECRETS_REPO=

# LATCH_UPDATE_REPO - GitHub repository used by LXC helpers to install/update the latch binary
LATCH_UPDATE_REPO=

# LATCH_UPDATE_ASSET - Release asset used for native latch installs inside LXCs
LATCH_UPDATE_ASSET=

# LATCH_UPDATE_INTERVAL_SECS - Minimum seconds between guarded latch update checks in each LXC
LATCH_UPDATE_INTERVAL_SECS=

# LATCH_AUTO_SYNC - Auto-run latch commit/push during Makefile build/release flows on desktop
# - 1 = enabled (default), 0 = disabled
LATCH_AUTO_SYNC=

# LATCH_SYNC_REQUIRED - Enforce latch sync success in Makefile build/release flows
# - 1 = fail build/release when latch commit/push fails
# - 0 = continue with warning on latch sync issues
LATCH_SYNC_REQUIRED=

# HOST_LATCH_PULL_ON_UPDATE - Run latch pull --sparse before HOST API/RPC remote update checks
# - true = enabled, false = disabled
HOST_LATCH_PULL_ON_UPDATE=

# LXC_LATCH_PULL_ON_UPDATE - Run latch pull --sparse before LXC API/RPC self-update command
# - true = enabled, false = disabled
LXC_LATCH_PULL_ON_UPDATE=

# BACKUP CONFIGURATION (Restic)
# =============================================================================

# RESTIC_REPOSITORY - Target location for all restic backups
# - Examples:
#   - Local: /HDD2TB/backups/restic or /mnt/nas/backups/restic
#   - S3: s3:s3.amazonaws.com/my-bucket/restic
#   - Google Drive: rclone:gdrive:homelab-backups
#   - B2: b2:bucket-name:restic-backup
# - SENSITIVE: Cloud URLs may contain credentials
RESTIC_REPOSITORY=

# RESTIC_PASSWORD - Encryption password for the restic backup repository
# - Create a strong, unique passphrase and store securely (password manager)
# - WARNING: Backups cannot be recovered without this password
# - SENSITIVE: Never commit this value
RESTIC_PASSWORD=

# RESTIC_REPO_BASE - Base directory for per-stack restic repositories on HOST
# - HOST stores per-stack backups under {RESTIC_REPO_BASE}/{STACK_NAME}/
# - Example: /backups/media, /backups/gateway
RESTIC_REPO_BASE=

# RCLONE_CONFIG_FILE - Optional path to rclone config for cloud backup backends
# - Required only for rclone-based backends (Google Drive, S3, B2)
# - Example: /root/.config/rclone/rclone.conf
# - Set up rclone separately: https://rclone.org/docs/configure/
RCLONE_CONFIG_FILE=

# =============================================================================
# HOST DAEMON SELF-UPDATE POLICY
# =============================================================================

# HOST_UPDATE_ASSET - Release asset filename to download for HOST daemon updates
# - Must match a release asset name in your GitHub releases
# - Typical value: "HOST" (matches the Makefile release target)
HOST_UPDATE_ASSET=

# HOST_UPDATE_TOKEN - Optional GitHub token for accessing private releases
# - Only required if your releases are private
# - Uses GITHUB_PAT by default (see above)
HOST_UPDATE_TOKEN=

# =============================================================================
# HOST FAILSAFE & LIVENESS POLICY
# =============================================================================
# These control HOST daemon emergency self-update behavior when CLIENT is offline.

# FAILSAFE_SYNC_INTERVAL_SECS - Interval (in seconds) between failsafe sync windows
# - Default: 3600 (1 hour)
# - Minimum enforced: 60 seconds
# - Lower values = more frequent emergency checks (may cause unnecessary updates)
# - Recommended: 3600 (hourly) to 7200 (every 2 hours)
FAILSAFE_SYNC_INTERVAL_SECS=

# HEARTBEAT_TTL_SECS - Maximum age (in seconds) of CLIENT heartbeat before HOST considers it stale
# - Default: 180 (3 minutes)
# - CLIENT sends heartbeat every ~30 seconds via WebSocket/HTTP
# - Should be 3-4x the heartbeat interval
# - If set too low, HOST may update unnecessarily even when CLIENT is responsive
HEARTBEAT_TTL_SECS=

# HOST_LOG_HISTORY_MAX - Max HOST log lines retained in memory for CLIENT reconnect replay
# - Default: 10000
# - HOST clamps this value to range 50..10000
HOST_LOG_HISTORY_MAX=

# LXC_LOG_HISTORY_MAX - Max LXC log lines retained in memory for CLIENT reconnect replay
# - Default: 10000
# - LXC clamps this value to range 50..10000
LXC_LOG_HISTORY_MAX=

# LOG_HISTORY_AGE_SECS - Age threshold for counting old HOST/LXC logs toward the cap
# - Default: 3600 (1 hour)
LOG_HISTORY_AGE_SECS=

# GITOPS_REPO_TOKEN - Git credential token for LXC sparse-checkout cloning during bootstrap
# - Typically a GitHub Personal Access Token (see GITHUB_PAT above)
# - Used for non-interactive Git operations in LXC bootstrap script
GITOPS_REPO_TOKEN=