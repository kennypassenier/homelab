# LXC daemon environment
# NOTE: This file is automatically created and managed by HOST bootstrap process
# Manual edits should be placed in /root/.env inside the container

# ========================================
# Stack Identity
# ========================================
# Set by HOST during bootstrap - identifies which stack this LXC manages
STACK_NAME=
STACK_IP=

# ========================================
# GitOps Repository Access
# ========================================
# Repository URL for GitOps sync (sparse checkout to stacks/{STACK_NAME})
GITOPS_REPO_URL=

# Personal access token for private repository access (injected by HOST bootstrap)
GITOPS_REPO_TOKEN=

# ========================================
# Sync Configuration (optional)
# ========================================
# GitOps sync interval in seconds (default: 1800 = 30 minutes)
# FAILSAFE_SYNC_INTERVAL_SECS=1800

# Heartbeat TTL - how long to wait for CLIENT heartbeat before failsafe sync (default: 180s = 3 minutes)
# HEARTBEAT_TTL_SECS=180

# ========================================
# Secrets (injected by HOST bootstrap)
# ========================================
# Latch credentials for secrets management
# LATCH_PAT=ghp_your_github_personal_access_token_here
# LATCH_KEY=your_latch_encryption_key_here

# ========================================
# API Configuration (optional)
# ========================================
# LXC daemon HTTP API authentication token
LXC_API_TOKEN=