# Homelab Central Configuration Template
#
# This is the SINGLE SOURCE OF TRUTH for all runtime environment variables across CLIENT, HOST, and LXC daemons.
# Copy this file to config/.env and fill in your values based on your homelab setup.
# NEVER commit config/.env to Git—it contains secrets and personal configuration.
#
# Each variable is documented with:
# - Purpose: what the variable controls
# - Default: fallback value if not set
# - How to obtain: where to find the correct value for your setup
#
# Environment precedence:
# - CLIENT uses: CLIENT_ENV_FILE (if set) → config/.env → no env
# - HOST uses: HOST_ENV_FILE (if set) → config/.env → no env
# - LXC uses: LXC_ENV_FILE (if set) → config/.env → no env

# =============================================================================
# CORE NETWORKING & API
# =============================================================================

# LXC_API_IP
# Purpose: Default HTTP endpoint for LXC daemon API when a stack has no reserved IPv4.
# Default: 127.0.0.1
# How to obtain: Use 127.0.0.1 if you always define reserved_ipv4 per stack (recommended).
#   Otherwise use the network IP of your primary LXC container.
LXC_API_IP=127.0.0.1

# LXC_API_TOKEN
# Purpose: Bearer token for all LXC daemon /api/* endpoints and WebSocket authentication.
#   Also used by HOST `GET /api/metrics` when token auth is enabled.
# Default: empty (no auth required)
# How to obtain: Generate a random 64-char hex string (e.g., `openssl rand -hex 32`).
#   Set the same value on all LXC daemons and CLIENT for consistency.
LXC_API_TOKEN=

# HOST_IP
# Purpose: IP address of the Proxmox host for CLIENT Host Management metrics retrieval.
# Default: 10.10.5.250
# How to obtain: Check your Proxmox host's primary IP (e.g., `ip addr` on the host).
#   Host Management tab uses HTTP API (not SSH) to fetch runtime metrics.
HOST_IP=10.10.5.250

# =============================================================================
# CLIENT BEHAVIOR & ORCHESTRATION
# =============================================================================

# BACKUP_ID_DEFAULT
# Purpose: Default backup snapshot ID shown in the CLIENT restore workflow.
# Default: latest
# How to obtain: Use "latest" for most cases, or a specific backup ID from your restic repo.
BACKUP_ID_DEFAULT=latest

# HOST_UPDATE_REPO
# Purpose: GitHub repository to query for HOST daemon release-based updates.
# Default: kennypassenier/homelab
# How to obtain: Owner/repo of your GitHub fork or origin.
HOST_UPDATE_REPO=kennypassenier/homelab

# LXC_DAEMON_IMAGE
# Purpose: Docker/OCI image source for LXC daemon self-updates.
# Default: ghcr.io/kennypassenier/homelab-lxc-daemon:latest
# How to obtain: GHCR image published by your CI/CD pipeline.
#   Format: ghcr.io/<owner>/<repo>-lxc-daemon:tag
LXC_DAEMON_IMAGE=ghcr.io/kennypassenier/homelab-lxc-daemon:latest

# DOMAIN
# Purpose: Base domain suffix for Traefik app wizard subdomain configuration.
# Default: example.com
# How to obtain: Your homelab domain (e.g., kp-soft.dev, home.example.com).
#   When creating a Traefik-enabled app, the wizard asks for subdomain, then appends
#   ".{DOMAIN}" to create the full ingress hostname.
DOMAIN=example.com

# STACK_IP_PREFIX
# Purpose: Network prefix used to derive reserved IPv4 for each stack.
# Default: 10.10.10.
# How to obtain: Choose a private subnet prefix that doesn't conflict with your existing network.
#   Formula: reserved_ipv4 = {STACK_IP_PREFIX} + ({VMID} - 100)
#   Example: VMID 105 → 10.10.10.5 (with default prefix)
STACK_IP_PREFIX=10.10.10.

# =============================================================================
# OPNSENSE INTEGRATION (Optional, for DHCP reservation sync)
# =============================================================================
# These variables enable CLIENT to automatically sync stack DHCP reservations to OPNsense.
# Leave empty to disable DHCP automation.

# OPNSENSE_BASE_URL
# Purpose: Base URL of your OPNsense API endpoint.
# Default: empty (disabled)
# How to obtain: https://<opnsense-ip>, e.g., https://10.10.5.1
#   Verify you can access the OPNsense web UI at this URL.
OPNSENSE_BASE_URL=

# OPNSENSE_API_KEY
# Purpose: API key for OPNsense authentication.
# Default: empty (disabled)
# How to obtain: OPNsense WebUI → System → Access → Users → Select your user →
#   API Keys section → Generate a new key → copy the key value.
OPNSENSE_API_KEY=

# OPNSENSE_API_SECRET
# Purpose: API secret paired with OPNSENSE_API_KEY.
# Default: empty (disabled)
# How to obtain: Generated together with the API key in OPNsense (same location).
#   This is shown once; save both key and secret immediately.
OPNSENSE_API_SECRET=

# OPNSENSE_TLS_INSECURE
# Purpose: Whether to skip TLS certificate verification for OPNsense API calls.
# Default: false
# How to obtain: Set to true ONLY for lab/self-signed TLS setups. Never true in production.
OPNSENSE_TLS_INSECURE=false

# =============================================================================
# GIT & REPOSITORY CONFIGURATION
# =============================================================================

# GITOPS_REPO
# Purpose: Absolute filesystem path to the GitOps repository on the Proxmox host.
# Default: ${HOME}/homelab (e.g., /root/homelab)
# How to obtain: Where you cloned the homelab repository on the HOST machine.
#   HOST daemon uses this to find stacks/ and scripts/ directories.
GITOPS_REPO=/root/homelab

# GITOPS_REPO_URL
# Purpose: Git remote URL for cloning/pulling the GitOps repository.
# Default: https://github.com/kennypassenier/homelab.git
# How to obtain: URL of your public or private GitHub repository.
#   Format: https://github.com/owner/repo.git or git@github.com:owner/repo.git
GITOPS_REPO_URL=https://github.com/kennypassenier/homelab.git

# GITHUB_USERNAME
# Purpose: GitHub username used to fetch public SSH keys for LXC bootstrap.
# Default: empty
# How to obtain: Your GitHub username (e.g., kennypassenier).
#   Used to fetch public SSH keys from https://github.com/{username}.keys
GITHUB_USERNAME=

# GITHUB_PAT
# Purpose: GitHub Personal Access Token for private repository access.
# Default: empty
# How to obtain: GitHub → Settings → Developer settings → Personal access tokens → Tokens (classic) →
#   Generate new token with 'repo' and 'read:user' scopes.
#   SENSITIVE: Never commit this value.
GITHUB_PAT=

# =============================================================================
# SECRET MANAGEMENT (Latch)
# =============================================================================

# LATCH_PAT
# Purpose: Latch Personal Access Token for secret synchronization on HOST and LXC.
# Default: empty
# How to obtain: Obtain from your Latch infrastructure or contact your team admin.
#   Used for non-interactive secret cloning and sync flows.
#   SENSITIVE: Never commit this value.
LATCH_PAT=

# LATCH_KEY
# Purpose: Latch encryption key paired with LATCH_PAT.
# Default: empty
# How to obtain: Generated and distributed by your Latch admin together with LATCH_PAT.
#   SENSITIVE: Never commit this value.
LATCH_KEY=

# BACKUP CONFIGURATION (Restic)
# =============================================================================

# RESTIC_REPOSITORY
# Purpose: Target location for all restic backups (local or remote).
# Default: /HDD2TB/backups/restic
# How to obtain: A filesystem path or remote URL where backups will be stored.
#   Examples:
#   - Local disk: /mnt/backups/restic or /HDD2TB/backups/restic
#   - S3 (AWS/MinIO): s3:s3.amazonaws.com/my-bucket/restic
#   - Google Drive via rclone: rclone:gdrive:homelab-backups
#   - B2: b2:bucket-name:restic-backup
#   SENSITIVE: If using S3/cloud backends, URL may contain credentials.
RESTIC_REPOSITORY=/HDD2TB/backups/restic

# RESTIC_PASSWORD
# Purpose: Encryption password for the restic backup repository.
# Default: empty
# How to obtain: Create a strong, unique passphrase.
#   Store securely (password manager) and do NOT lose it—backups cannot be recovered without it.
#   SENSITIVE: Never commit this value.
RESTIC_PASSWORD=

# RESTIC_REPO_BASE
# Purpose: Base directory path for per-stack restic repositories on HOST.
# Default: /backups
# How to obtain: Directory path accessible by HOST daemon for per-stack backup targets.
#   HOST stores per-stack backups under {RESTIC_REPO_BASE}/{STACK_NAME}/.
RESTIC_REPO_BASE=/backups

# RCLONE_CONFIG_FILE
# Purpose: Optional path to rclone config file for cloud-based backup backends.
# Default: empty (rclone auto-discovers config)
# How to obtain: Path to your rclone config, e.g., ~/.config/rclone/rclone.conf
#   Required only if you use cloud backends (Google Drive, S3, etc.) for backups.
#   Set up rclone separately: https://rclone.org/
RCLONE_CONFIG_FILE=

# =============================================================================
# HOST DAEMON SELF-UPDATE POLICY
# =============================================================================

# HOST_UPDATE_ASSET
# Purpose: Release asset filename to download for HOST daemon self-updates.
# Default: HOST
# How to obtain: Binary name from GitHub releases (typically "HOST" for our build).
#   Must match a release asset filename in your repository's GitHub releases.
HOST_UPDATE_ASSET=HOST

# HOST_UPDATE_TOKEN
# Purpose: Optional GitHub token for accessing private GitHub releases (rarely needed).
# Default: empty
# How to obtain: GitHub Personal Access Token (see GITHUB_PAT above).
#   Only required if your releases are private.
HOST_UPDATE_TOKEN=

# =============================================================================
# HOST FAILSAFE & LIVENESS POLICY
# =============================================================================
# These control the HOST daemon's emergency self-update behavior when CLIENT is offline.

# FAILSAFE_SYNC_INTERVAL_SECS
# Purpose: Interval (in seconds) between HOST failsafe sync windows.
# Default: 3600 (1 hour)
# How to obtain: Recommended 3600 (hourly). Lower values = more frequent checks.
#   Minimum 60 seconds enforced by HOST.
#   Set higher if you want less frequent emergency checks.
FAILSAFE_SYNC_INTERVAL_SECS=3600

# HEARTBEAT_TTL_SECS
# Purpose: Maximum age (in seconds) of CLIENT heartbeat signal before HOST considers it stale.
# Default: 180 (3 minutes)
# How to obtain: Should be longer than heartbeat pulse interval (CLIENT sends every 30 sec).
#   Recommended: 180-240 seconds (3-4 minutes).
#   If set too low, HOST may update unnecessarily even while CLIENT is responsive.
HEARTBEAT_TTL_SECS=180

# HOST_LOG_HISTORY_MAX
# Purpose: Max HOST log lines kept in memory for WebSocket replay when CLIENT reconnects.
# Default: 500
# How to obtain: Keep 500 for normal use; raise if you need more reconnect history.
#   Valid range is clamped by HOST to 50..10000.
HOST_LOG_HISTORY_MAX=500

# GITOPS_REPO_TOKEN
# Purpose: Git credential token for LXC sparse-checkout cloning during bootstrap.
# Default: empty
# How to obtain: GitHub Personal Access Token (see GITHUB_PAT above) or HTTPS credential.
#   Used by LXC to clone the Git repository without interactive auth.
GITOPS_REPO_TOKEN=

# =============================================================================
# NOTES ON SECURITY & GIT MANAGEMENT
# =============================================================================
#
# SENSITIVE VALUES:
# - LXC_API_TOKEN: Bearer token (treat as password)
# - GITHUB_PAT: GitHub auth (highly sensitive)
# - LATCH_PAT, LATCH_KEY: Secret management credentials
# - RESTIC_PASSWORD: Backup encryption key
# - All values ending in *_TOKEN or *_KEY
#
# These MUST NOT be committed to Git. Ensure config/.env is in .gitignore.
#
# SAFE CONFIGURATION OPTIONS:
# - IPs, domains, URLs, image names, and app-level config can be safely committed to Git
# - Use external secret management (Latch or Vault) for sensitive values
# - Consider using separate .env files per environment (dev/staging/prod) with different paths
#
# GIT EXCLUDE:
# Verify that config/.env is listed in .gitignore to prevent accidental commits.
# You can also use: git update-index --assume-unchanged config/.env
