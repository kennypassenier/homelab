# HOST daemon environment

# ========================================
# GitOps Provisioning & Bootstrap
# ========================================
# Required for automated LXC provisioning and bootstrap
GITOPS_REPO=/opt/gitops
GITOPS_REPO_URL=https://github.com/kennypassenier/homelab.git
GITHUB_PAT=ghp_your_github_personal_access_token_here
GITHUB_USERNAME=kennypassenier

# Secrets injection (INFISICAL_* vars are injected into LXCs during bootstrap)
INFISICAL_TOKEN=your_infisical_token_here
INFISICAL_PROJECT_ID=your_infisical_project_id_here
INFISICAL_ENVIRONMENT=prod

# LXC daemon binary source (optional)
# If not set, HOST looks for: /opt/homelab/lxc-daemon/target/release/LXC
# LXC_DAEMON_URL=ghcr.io/kennypassenier/homelab/lxc-daemon:latest

# ========================================
# Self-Update Configuration
# ========================================
# GitHub repository to query for release-based self-update.
HOST_UPDATE_REPO=kennypassenier/homelab

# Release asset name expected in the GitHub release.
HOST_UPDATE_ASSET=HOST-linux-x86_64-unknown-linux-gnu

# Optional GitHub token for private release access.
HOST_UPDATE_TOKEN=

# HOST failsafe self-update policy (inverse heartbeat model).
# Every interval window, HOST checks for a recent CLIENT heartbeat; if stale/missing,
# it performs an emergency release self-update check.
FAILSAFE_SYNC_INTERVAL_SECS=3600
HEARTBEAT_TTL_SECS=180
HOST_HEARTBEAT_FILE=/tmp/homelab-client-heartbeat.ts

# Optional per-stack IPs used by HOST backup orchestration.
LXC_CLOUDFLARED_IP=10.0.1.101
LXC_DOWNLOADER_IP=10.0.1.102
LXC_GATEWAY_IP=10.0.1.103
LXC_MEDIA_IP=10.0.1.104
LXC_MONITORING_IP=10.0.1.105
LXC_PAPERLESS_IP=10.0.1.106
LXC_VIKUNJA_IP=10.0.1.107

# Optional restic repository base for HOST daemon per-stack backup mode.
# Examples:
# - local base: /backups
# - Google Drive via rclone: rclone:gdrive:homelab
RESTIC_REPO_BASE=/backups

# Optional rclone config file path for rclone-backed restic repositories.
# RCLONE_CONFIG_FILE=/root/.config/rclone/rclone.conf
