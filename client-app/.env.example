# CLIENT TUI environment
# Default LXC API endpoint if no per-stack override is present.
LXC_API_IP=

# Optional bearer token for LXC /api/sync calls.
LXC_API_TOKEN=

# Optional HOST heartbeat SSH target (used for inverse failsafe suppression).
# CLIENT will periodically execute: ssh <alias> 'date +%s > <HOST_HEARTBEAT_FILE>'
HOST_HEARTBEAT_SSH_ALIAS=
HOST_HEARTBEAT_FILE=

# Optional OPNsense API settings for DHCP reservation automation.
OPNSENSE_BASE_URL=
OPNSENSE_API_KEY=
OPNSENSE_API_SECRET=
OPNSENSE_TLS_INSECURE=

# Latch credentials used by CLIENT for secrets sync and machine clone.
LATCH_PAT=
LATCH_KEY=

# Optional per-stack endpoint overrides used when CLIENT dispatches sync requests.
LXC_CLOUDFLARED_IP=
LXC_DOWNLOADER_IP=
LXC_GATEWAY_IP=
LXC_MEDIA_IP=
LXC_MONITORING_IP=
LXC_PAPERLESS_IP=
LXC_VIKUNJA_IP=